{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "runoot.com"
        }
      ],
      "destination": "https://www.runoot.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/ph/static/:path*",
      "destination": "https://eu-assets.i.posthog.com/static/:path*"
    },
    {
      "source": "/ph/:path*",
      "destination": "https://eu.i.posthog.com/:path*"
    },
    {
      "source": "/ph/decide",
      "destination": "https://eu.i.posthog.com/decide"
    }
  ]
}
